# OS/editor noise
.DS_Store
Thumbs.db
*.iml

# Local IDE state
.idea/
.vscode/
.cursor/mcp.json

# Android/Gradle generated state
.gradle/
.kotlin/
build/
captures/
.externalNativeBuild/
.cxx/

# Generated build outputs anywhere in the workspace
**/build/
**/.gradle/
**/.kotlin/
**/captures/
