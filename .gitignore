# Local SDK and machine-specific configuration
local.properties
**/local.properties

# Release/signing artifacts must not be committed
*.apk
*.aab
*.ap_
*.jks
*.keystore
*.p12
*.pem

# Legacy/generated project copy kept locally for reference only
_legacy-root-android/

# Local MCP Python environment (do not commit)
mcp/.venv/

# Android platform-tools bundle (local tooling only)
android-app/tools/

# Python bytecode
**/__pycache__/
*.pyc
